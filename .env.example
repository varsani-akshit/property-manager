# Copy to .env.local (or .env) and fill in your own Supabase project credentials.
# Find these in your Supabase dashboard.

# Project Settings → Database → Connect → Session pooler URI
# (the direct connection URL is IPv6-only on new projects; always use the pooler)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres"

# Project Settings → API Keys → Project URL
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"

# Project Settings → API Keys → publishable key (safe for browser, requires RLS)
# Do NOT use the secret/service_role key here — it would be exposed to every visitor.
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxx"

# Project Settings → API Keys → secret / service_role key.
# SERVER-ONLY. Used to send user invites and delete users from the /users page.
# Never prefix this with NEXT_PUBLIC_; never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY="sb_secret_xxxxxxxxxxxxxxxxxxxx"

# The public URL of your deployed app — used in invite email "redirect to" links.
# In local dev leave it as http://localhost:3000; in Vercel set it to your domain.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Google Drive integration (for in-app uploads of property deeds + lease documents).
# Setup steps (one-time, in Google Cloud Console):
#   1. Create / select a Google Cloud project
#   2. Enable the "Google Drive API"
#   3. IAM & Admin → Service Accounts → Create service account
#   4. Keys tab → Add key → JSON → download. The JSON below = the entire file contents.
#   5. Copy the service account email (looks like xxx@yyy.iam.gserviceaccount.com)
#   6. In Google Drive, create a folder (e.g. "Variaka Property Docs"), right-click → Share → paste the
#      service account email with "Editor" permission.
#   7. Open the folder, the URL is .../folders/<ID>. Copy the ID.
#
# IMPORTANT: paste the JSON as a single-line string. The newlines inside private_key must be \n
# (literal backslash-n). On Vercel, paste the full multi-line JSON into the env var input;
# it handles newlines fine. If you prefer base64-encoding the JSON to avoid any quoting headaches,
# the app accepts that too.
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"xxx@yyy.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}'
GOOGLE_DRIVE_PARENT_FOLDER_ID="paste-the-folder-id-here"
