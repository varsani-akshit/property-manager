# Copy to .env.local (or .env) and fill in your own Supabase project credentials.
# Find these in your Supabase dashboard.

# Project Settings → Database → Connect → Session pooler URI
# (the direct connection URL is IPv6-only on new projects; always use the pooler)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres"

# Project Settings → API Keys → Project URL
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"

# Project Settings → API Keys → publishable key (safe for browser, requires RLS)
# Do NOT use the secret/service_role key here — it would be exposed to every visitor.
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxx"
